{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "telOS",
  "version": "0.0.1",
  "identifier": "com.telooss.telos",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "telOS",
        "width": 1280,
        "height": 720,
        "fullscreen": true,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self'; script-src 'self'; font-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "C:/Program Files (x86)/Steam/appcache/librarycache/**",
          "C:/Program Files/Steam/appcache/librarycache/**",
          "C:/Steam/appcache/librarycache/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
